# Copy this file to ".env" and fill in your Supabase project's values.
# Find them in the Supabase dashboard: Project Settings -> API.
# When both are set, src/supabase.js uses the real backend; otherwise it falls
# back to the in-browser localStorage mock (src/supabaseMock.js).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
